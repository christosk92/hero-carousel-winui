<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="HeroCarousel.Demo.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:HeroCarousel.Demo"
    xmlns:hc="using:HeroCarousel"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!--
        Demo host: the entire carousel feature lives under the HeroCarousel/
        folder and is exposed as the HeroCarouselView UserControl.
    -->
    <Grid>
        <hc:HeroCarouselView
            x:Name="HeroCarousel"
            AutoAdvanceInterval="0:0:6"
            IsAutoAdvanceEnabled="True" />
    </Grid>
</Page>
